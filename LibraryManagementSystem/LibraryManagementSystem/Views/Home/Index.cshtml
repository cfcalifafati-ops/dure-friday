@{
    ViewData["Title"] = "Dashboard";
}
<h1>Library Management Dashboard</h1>
<p class="lead">Manage books, members, borrowing and returns.</p>
<div class="row g-3">
    <div class="col-md-3"><div class="card p-3 shadow-sm"><h5>Total Books</h5><h2>@ViewBag.TotalBooks</h2></div></div>
    <div class="col-md-3"><div class="card p-3 shadow-sm"><h5>Total Members</h5><h2>@ViewBag.TotalMembers</h2></div></div>
    <div class="col-md-3"><div class="card p-3 shadow-sm"><h5>Borrowed</h5><h2>@ViewBag.BorrowedBooks</h2></div></div>
    <div class="col-md-3"><div class="card p-3 shadow-sm"><h5>Overdue</h5><h2>@ViewBag.OverdueBooks</h2></div></div>
</div>
<div class="mt-4">
    <a class="btn btn-primary" asp-controller="Books" asp-action="Index">Manage Books</a>
    <a class="btn btn-success" asp-controller="BorrowRecords" asp-action="Create">Borrow a Book</a>
</div>
