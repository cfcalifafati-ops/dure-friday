@model BorrowRecord
@{ ViewData["Title"] = "Borrow Book"; }
<h1>Borrow Book</h1>
<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3"><label asp-for="BookId" class="form-label">Book</label><select asp-for="BookId" asp-items="ViewBag.BookId" class="form-select"></select><span asp-validation-for="BookId" class="text-danger"></span></div>
    <div class="mb-3"><label asp-for="MemberId" class="form-label">Member</label><select asp-for="MemberId" asp-items="ViewBag.MemberId" class="form-select"></select><span asp-validation-for="MemberId" class="text-danger"></span></div>
    <div class="mb-3"><label asp-for="BorrowDate" class="form-label"></label><input asp-for="BorrowDate" class="form-control" /></div>
    <div class="mb-3"><label asp-for="DueDate" class="form-label"></label><input asp-for="DueDate" class="form-control" /></div>
    <button class="btn btn-primary">Save</button>
    <a class="btn btn-secondary" asp-action="Index">Back</a>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
