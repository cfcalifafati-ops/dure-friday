@model IEnumerable<BorrowRecord>
@{ ViewData["Title"] = "Borrow Records"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Borrow Records</h1>
    <a class="btn btn-primary" asp-action="Create">Borrow Book</a>
</div>
<table class="table table-bordered table-striped">
<thead><tr><th>Book</th><th>Member</th><th>Borrowed</th><th>Due</th><th>Returned</th><th>Status</th><th></th></tr></thead>
<tbody>
@foreach (var item in Model) {
<tr>
    <td>@item.Book?.Title</td><td>@item.Member?.FullName</td><td>@item.BorrowDate.ToShortDateString()</td><td>@item.DueDate.ToShortDateString()</td><td>@item.ReturnDate?.ToShortDateString()</td><td>@item.Status</td>
    <td>
        @if (item.Status == "Borrowed") { <a class="btn btn-sm btn-success" asp-action="ReturnBook" asp-route-id="@item.BorrowRecordId">Return</a> }
        <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.BorrowRecordId">Delete</a>
    </td>
</tr>
}
</tbody>
</table>
