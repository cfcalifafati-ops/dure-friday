@model IEnumerable<Member>
@{ ViewData["Title"] = "Members"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Members</h1>
    <a class="btn btn-primary" asp-action="Create">Add Member</a>
</div>
<table class="table table-bordered table-striped">
<thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Date Joined</th><th></th></tr></thead>
<tbody>
@foreach (var item in Model) {
<tr>
    <td>@item.FullName</td><td>@item.Email</td><td>@item.Phone</td><td>@item.DateJoined.ToShortDateString()</td>
    <td><a asp-action="Edit" asp-route-id="@item.MemberId">Edit</a> | <a asp-action="Delete" asp-route-id="@item.MemberId">Delete</a></td>
</tr>
}
</tbody>
</table>
