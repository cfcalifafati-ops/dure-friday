<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Library System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
  <div class="container">
    <a class="navbar-brand" asp-controller="Home" asp-action="Index">Library System</a>
    <div class="navbar-nav">
      <a class="nav-link" asp-controller="Books" asp-action="Index">Books</a>
      <a class="nav-link" asp-controller="Members" asp-action="Index">Members</a>
      <a class="nav-link" asp-controller="BorrowRecords" asp-action="Index">Borrow Records</a>
      <a class="nav-link" asp-controller="Account" asp-action="Logout">Logout</a>
    </div>
  </div>
</nav>
<main class="container pb-5">
    @RenderBody()
</main>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
